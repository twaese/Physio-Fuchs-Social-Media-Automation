    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst now = new Date();\nconst results = [];\nconst skipped = [];\n\nfunction clean(v) { return String(v || '').trim(); }\nfunction findVideoUrl(f, comments) {\n  const candidates = [\n    clean(f.Video_Public_URL),\n    clean(f.video_public_url),\n    clean(f.field_9),\n    clean(f.LinkTitel),\n  ].filter(Boolean);\n  const m = comments.match(/(?:Video_Public_URL|Public Video URL|Video URL)\\s*:\\s*(https?:\\/\\/\\S+)/i);\n  if (m) candidates.unshift(m[1]);\n  return candidates.find(url => /^https?:\\/\\//i.test(url) && /\\.(mp4|mov)(\\?|#|$)/i.test(url)) || '';\n}\nfunction extract(label, comments) {\n  const re = new RegExp('- ' + label + ':\\\\s*([^\\\\n]+)', 'i');\n  const m = comments.match(re);\n  return m ? m[1].trim().toLowerCase() : '';\n}\n\nfor (const item of items) {\n  const f = item.json.fields || {};\n  const status = clean(f.field_6 || f.Status);\n  const itemId = item.json.id || item.json.Ausweis || f.id || f.ID;\n  const title = clean(f.Title || f.field_1);\n  const freigabe = clean(f.field_11 || f.Freigabe_Person);\n  const caption = clean(f.field_10 || f.Caption_Variante);\n  const hashtags = clean(f.field_7 || f.Hashtag_Thema);\n  const comments = clean(f.field_13 || f.Kommentare);\n  const videoUrl = findVideoUrl(f, comments);\n  const datumRaw = f.Ver_x00f6_ffentlichungsdatum || '';\n  const uhrzeit = clean(f.field_5 || '09:00');\n  const reasons = [];\n\n  if (status !== 'Reel freigegeben') reasons.push('status=' + (status || 'leer'));\n  if (freigabe.toLowerCase() !== 'judith') reasons.push('freigabe=' + (freigabe || 'leer'));\n  if (!caption) reasons.push('caption_fehlt');\n  if (!videoUrl) reasons.push('video_public_url_fehlt');\n\n  const personen = extract('Personen sichtbar', comments);\n  const einverstaendnis = extract('Einverstaendnis vorhanden', comments) || extract('Einverständnis vorhanden', comments);\n  if (personen === 'ja' && einverstaendnis !== 'ja') reasons.push('einverstaendnis_fehlt');\n\n  if (datumRaw) {\n    const dateOnly = String(datumRaw).split('T')[0];\n    const scheduledTime = new Date(dateOnly + 'T' + uhrzeit + ':00');\n    if (!isNaN(scheduledTime) && scheduledTime > now) reasons.push('scheduled_future=' + dateOnly + ' ' + uhrzeit);\n  }\n\n  const debugRow = {\n    item_id: itemId,\n    title,\n    status,\n    freigabe,\n    has_caption: Boolean(caption),\n    has_video_public_url: Boolean(videoUrl),\n    video_url_preview: videoUrl || '',\n    scheduled: datumRaw ? String(datumRaw).split('T')[0] + ' ' + uhrzeit : '',\n    reasons,\n  };\n\n  if (reasons.length) {\n    skipped.push(debugRow);\n    continue;\n  }\n\n  results.push({ json: {\n    _wf06_ready: true,\n    item_id: itemId,\n    title,\n    video_url: videoUrl,\n    caption,\n    hashtags,\n    caption_with_hashtags: caption + (hashtags ? '\\n\\n' + hashtags : ''),\n    fb_description: caption,\n    sp_fields: f,\n    existing_log: comments,\n  }});\n}\n\nif (results.length > 0) return results.slice(0, 1);\n\nreturn [{ json: {\n  _wf06_ready: false,\n  debug: 'Kein Item hat den WF-06 Preflight bestanden. Diese Debug-Ausgabe wird nicht gepostet.',\n  checked_items: items.length,\n  skipped: skipped.slice(0, 20),\n}}];"
      },
