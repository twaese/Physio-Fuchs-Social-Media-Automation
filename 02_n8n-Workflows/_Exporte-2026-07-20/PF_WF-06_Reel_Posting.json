      "parameters": {
        "jsCode": "const item = $('Filter: Reel freigegeben + Preflight').item.json;\nconst igResp = $('IG: Reel Publish').item.json || {};\nconst fbResp = $('FB: Page Video').item.json || {};\nconst igPostId = igResp.id || '';\nconst fbPostId = fbResp.id || fbResp.video_id || '';\nconst now = new Date().toISOString().slice(0, 16).replace('T', ' ');\nconst log = [\n  item.existing_log || '',\n  `${now} WF-06: Reel/Video veroeffentlicht - IG ${igPostId || 'unbekannt'} / FB ${fbPostId || 'unbekannt'}`,\n  `Video_Public_URL: ${item.video_url}`,\n].filter(Boolean).join('\\n');\nreturn [{ json: {\n  _sp_item_id: item.item_id,\n  payload: {\n    field_6: 'Veröffentlicht',\n    field_12: igPostId,\n    field_13: log,\n  }\n}}];"
