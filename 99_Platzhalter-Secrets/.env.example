# =====================================================================
# Physio Fuchs – Social Media Workflow – Beispiel-.env (Template)
# =====================================================================
# Diese Datei zeigt die STRUKTUR der echten .env, enthält aber
# AUSSCHLIESSLICH Platzhalter – KEINE realen Werte!
#
# Echte .env liegt unter:  ~/secrets/physio-fuchs/.env  (Permissions 600)
# Diese Beispieldatei darf im Repo bleiben.
# =====================================================================

# ---------- Microsoft 365 / SharePoint --------------------------------
SHAREPOINT_TENANT="<tenant>.sharepoint.com"
SHAREPOINT_SITE_PATH="/sites/<site-pfad>"
SHAREPOINT_SITE_URL="https://<tenant>.sharepoint.com/sites/<site-pfad>"
SHAREPOINT_SITE_DISPLAY="<Site-Anzeigename>"
SHAREPOINT_SITE_GUID="<site-guid>"
SHAREPOINT_WEB_GUID="<web-guid>"
SHAREPOINT_SITE_COMPOSITE="<tenant>.sharepoint.com,<site-guid>,<web-guid>"
SHAREPOINT_LIST_NAME="PF-Content-Kalender-2026"
SHAREPOINT_LIST_ID="<list-guid>"

ENTRA_TENANT_ID="<entra-tenant>"
ENTRA_CLIENT_ID="<app-client-id>"
ENTRA_CLIENT_SECRET="<app-client-secret>"

# ---------- Microsoft Teams -------------------------------------------
TEAMS_TEAM_ID="<team-id>"
TEAMS_CHANNEL_NAME="<channel-name>"
TEAMS_CHANNEL_ID="<channel-id>"
TEAMS_FREIGABE_CHANNEL_ID="<channel-id>"
TEAMS_ALERT_CHANNEL_ID="<channel-id>"
TEAMS_WEBHOOK_URL=""

# ---------- n8n -------------------------------------------------------
N8N_BASE_URL="https://n8n.<deine-domain>"
N8N_WEBHOOK_URL="${N8N_BASE_URL}/webhook"
N8N_API_KEY="<n8n-api-key>"

N8N_WF01_WEBHOOK_PATH="pf-wf01-content-einreichung"
N8N_WF03_WEBHOOK_RANDOM_ID="<uuid>"
N8N_WF03_WAIT_EXPORT_ID="wf03-wait-export"
N8N_WF03_WAIT_IG_ID="wf03-wait-ig"
N8N_WF03_WAIT_IG_V3_ID="wf03-wait-ig-v3"
N8N_WF03_WAIT_IG_V4_ID="wf03-wait-ig-v4"

# ---------- Meta (Instagram + Facebook) -------------------------------
META_API_VERSION="v25.0"
META_APP_ID="<meta-app-id>"
META_APP_SECRET="<meta-app-secret>"
META_ACCESS_TOKEN="<long-lived-token>"

INSTAGRAM_BUSINESS_ACCOUNT_ID="<ig-business-id>"
FACEBOOK_PAGE_ID="<fb-page-id>"

# ---------- Canva -----------------------------------------------------
CANVA_API_KEY="<canva-connect-key>"
CANVA_BRAND_KIT_ID="<brand-kit-id>"

CANVA_TPL_STANDARD="<template-id>"
CANVA_TPL_TIPP="<template-id>"
CANVA_TPL_ZITAT="<template-id>"
CANVA_TPL_STORY="<template-id>"
CANVA_TPL_TEAM="<template-id>"
CANVA_TPL_UEBUNG="<template-id>"
CANVA_TPL_PROMO="<template-id>"
CANVA_TPL_REEL_COVER="<template-id>"
CANVA_TPL_FEED_MYTHOS="<template-id>"
CANVA_TPL_FEED_NEWS="<template-id>"
CANVA_TPL_STORY_TIPP="<template-id>"

# ---------- LLM-Provider ----------------------------------------------
ANTHROPIC_API_KEY="<anthropic-key>"
ANTHROPIC_MODEL="claude-opus-4-7"
ANTHROPIC_VERSION_HEADER="2023-06-01"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# ---------- Avatar-/Voice-Tools (Roadmap-Phase 3) ---------------------
HEYGEN_API_KEY=""
HEYGEN_AVATAR_ID_JUDITH=""
HEYGEN_VOICE_ID_JUDITH=""
SYNTHESIA_API_KEY=""
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID_JUDITH=""

# ---------- Storage / OneDrive ----------------------------------------
ONEDRIVE_REELS_FOLDER_PATH=""
ONEDRIVE_AVATAR_TRAINING_PATH=""
