      "id": "wf00-get-items",
      "name": "Alle Items laden",
      "credentials": {
        "microsoftSharePointOAuth2Api": {
          "id": "jLaDM9Iq5mCQJkMU",
          "name": "PF Microsoft SharePoint account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = .all();\n\n// Nur Items ohne Veroeffentlichungsdatum (field_14)\nconst ohneDatum = items.filter(item => {\n  const f = item.json.fields || item.json;\n  return !f.field_14 || f.field_14 === '' || f.field_14 === null;\n});\n\nconsole.log('Gefunden: ' + items.length + ' Items total, ' + ohneDatum.length + ' ohne Datum');\n\n// Startdatum: heute + 7 Tage\nconst heute = new Date();\nheute.setHours(0,0,0,0);\n\nreturn ohneDatum.map((item, index) => {\n  const f = item.json.fields || item.json;\n  \n  // Datum berechnen: +7, +14, +21...\n  const d = new Date(heute);\n  d.setDate(d.getDate() + (7 * (index + 1)));\n  \n  const dd   = String(d.getDate()).padStart(2,'0');\n  const mm   = String(d.getMonth()+1).padStart(2,'0');\n  const yyyy = d.getFullYear();\n  const datum = yyyy+'-'+mm+'-'+dd+'T00:00:00Z';\n  \n  // Item-ID ermitteln\n  const itemId = parseInt(String(item.json.id || item.json.AUSWEIS || item.json.ID || 0).trim(), 10);\n  \n  return {\n    json: {\n      itemId,\n      datum,\n      index: index + 1,\n      thema: f.field_1 || f.Title || '(kein Thema)'\n    }\n  };\n});"
      },
