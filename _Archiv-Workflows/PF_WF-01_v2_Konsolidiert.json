      "parameters": {
        "jsCode": "const body = $input.item.json.body || $input.item.json;\n\n// Datum: ISO-String → \"YYYY-MM-DD\" (pure Date für SP \"Nur Datum\"-Spalten)\nfunction formatDatum(iso) {\n  if (!iso) return '';\n  const d = new Date(iso);\n  if (isNaN(d)) return iso;\n  const dd = String(d.getDate()).padStart(2, '0');\n  const mm = String(d.getMonth()+1).padStart(2, '0');\n  const yyyy = d.getFullYear();\n  return yyyy+'-'+mm+'-'+dd;  // ← nur Datum, ohne Zeit-Teil\n}\n\n// Pflichtfeld prüfen\nconst thema = (body.Thema || body.thema || '').trim();\nif (!thema) throw new Error('Pflichtfeld Thema fehlt');\n\nconst postTyp   = (body.Post_Typ        || body.postTyp          || 'Standard').trim();\nconst brief     = (body.Content_Brief   || body.textIdee         || '').trim();\nconst datum     = formatDatum(body.Veroeffentlichungsdatum || body.wunschDatum || '');\nconst uhrzeit   = (body.Uhrzeit         || body.uhrzeit          || '').trim();\nconst hashtag   = (body.Hashtag_Thema   || body.hashtag          || '').trim();\nconst bild      = (body.Bild_Dateiname  || body.bildBeschreibung || '').trim();\nconst freigabe  = (body.Freigabe_Person || 'Judith').trim();\nconst kommentar = (body.Kommentare      || body.notiz            || '').trim();\n\nreturn {\n  json: {\n    Title:    thema,\n    field_1:  thema,\n    field_2:  postTyp,\n    field_3:  brief,\n    field_5:  uhrzeit,\n    field_6:  'Entwurf',\n    field_7:  hashtag,\n    field_8:  bild,\n    field_11: freigabe,\n    field_13: kommentar,\n    Ver_x00f6_ffentlichungsdatum: datum,\n    _eingereichtVon: body._eingereichtVon || 'Judith',\n    _eingereichtAm:  body._eingereichtAm  || new Date().toISOString(),\n    _postTyp: postTyp,\n    _datum:   datum\n  }\n};"
      },
