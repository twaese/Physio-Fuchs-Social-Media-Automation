    {
      "parameters": {
        "jsCode": "// WF-03 v6 Filter: Karenz-Check + Schedule-Check\nconst items = $input.all();\nconst now = new Date();\nconst KARENZ_HOURS = 24;\nconst results = [];\nconst skipped = [];\n\nfor (const item of items) {\n  const j = item.json;\n  const f = j.fields || {};\n  const status = f.field_6;\n  const modified = j.lastModifiedDateTime || j.Modified;\n  const datumRaw = f.Ver_x00f6_ffentlichungsdatum;\n  const uhrzeit = (f.field_5 || '09:00').trim();\n  const itemId = j.id || j.Ausweis || f.AUSWEIS;\n  const title = f.Title || f.Titel || '';\n\n  const reasons = [];\n  if (status !== 'Bereit') reasons.push(`status=${status}`);\n\n  // Karenz-Check: muss seit Status=Bereit mind. 24h vergangen sein\n  if (modified) {\n    const modifiedDate = new Date(modified);\n    const hoursSinceModified = (now - modifiedDate) / (1000 * 60 * 60);\n    if (hoursSinceModified < KARENZ_HOURS) {\n      reasons.push(`karenz_läuft (${hoursSinceModified.toFixed(1)}h von ${KARENZ_HOURS}h)`);\n    }\n  } else {\n    reasons.push('modified_fehlt');\n  }\n\n  // Schedule-Check: geplantes Datum + Uhrzeit erreicht?\n  if (datumRaw) {\n    const dateOnly = String(datumRaw).split('T')[0];\n    const scheduledTime = new Date(`${dateOnly}T${uhrzeit}:00`);\n    if (isNaN(scheduledTime)) {\n      reasons.push(`schedule_invalid (${dateOnly} ${uhrzeit})`);\n    } else if (scheduledTime > now) {\n      reasons.push(`scheduled_future (${dateOnly} ${uhrzeit})`);\n    }\n  } else {\n    reasons.push('veröffentlichungsdatum_leer');\n  }\n\n  // Bild-URLs müssen da sein\n  const igUrl = f.field_9 || '';\n  const fbUrl = f.Bild_FB_Dateiname || '';\n  if (!igUrl.startsWith('https://')) reasons.push('field_9_keine_url');\n  if (!fbUrl.startsWith('https://')) reasons.push('Bild_FB_Dateiname_keine_url');\n\n  if (reasons.length > 0) {\n    skipped.push({ id: itemId, title, reasons });\n    continue;\n  }\n\n  const hashtags = f.field_7 || '';\n  const caption = (f.field_10 || '').trim();\n\n  results.push({\n    json: {\n      item_id: itemId,\n      title,\n      image_url_ig: igUrl,\n      image_url_fb: fbUrl,\n      caption,\n      hashtags,\n      caption_with_hashtags: caption + (hashtags ? '\\n\\n' + hashtags : ''),\n      sp_fields: f,\n    }\n  });\n}\n\nif (results.length === 0) {\n  return [{ json: {\n    info: 'Keine Items posting-bereit',\n    today: now.toISOString().slice(0, 16),\n    karenz_hours: KARENZ_HOURS,\n    total_items: items.length,\n    skipped: skipped.slice(0, 20)\n  }}];\n}\n\nreturn results.slice(0, 1);  // 1 Item pro Cron-Lauf (multi-item bug in v6)"
      },
