    {
      "parameters": {
        "jsCode": "// Build SP-Update Payload für Status=Veröffentlicht\nconst itemId = $('Filter: Karenz + Schedule').item.json.item_id;\nconst igResp = $('IG: Publish').item.json;\nconst fbResp = $('FB: Photo').item.json;\n\nconst igPostId = igResp.id || '';\nconst fbPostId = fbResp.id || fbResp.post_id || '';\n\nconst now = new Date().toISOString().replace('T', ' ').slice(0, 16);\nconst f = $('Filter: Karenz + Schedule').item.json.sp_fields;\nconst existingLog = f.field_13 || '';\nconst logEntry = `\\n${now} WF-03 v6: Veröffentlicht — IG ${igPostId || '✗'} / FB ${fbPostId || '✗'}`;\n\nreturn [{\n  json: {\n    _sp_item_id: itemId,\n    payload: {\n      field_6: 'Veröffentlicht',\n      field_12: igPostId,      // Instagram_Post_ID\n      field_13: existingLog + logEntry,\n    }\n  }\n}];"
      },
